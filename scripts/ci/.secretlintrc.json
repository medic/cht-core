{
  "rules": [
    {
      "id": "@secretlint/secretlint-rule-preset-recommend"
    },
    {
      "id": "@secretlint/secretlint-rule-pattern",
      "options": {
        "patterns": [
          {
            "name": "user:pass@host URL",
            "patterns": ["/[a-zA-Z][a-zA-Z0-9+\\-.]*:\\/\\/[^:\\s\\/]+:[^@\\s\\/]+@/"]
          },
          {
            "name": "credential in query parameter",
            "patterns": ["/(password|passwd|pass|token|secret|api[_-]key)=(?!\\*{3}|\\[REDACTED\\])[^&\\s\"']+/i"]
          },
          {
            "name": "credential in JSON key/value",
            "patterns": ["/\"(password|passwd|pass|token|secret|api[_-]key)\"\\s*:\\s*\"(?!\\*{3}|\\[REDACTED\\])[^\"]+\"/i"]
          },
          {
            "name": "Authorization header",
            "patterns": ["/\\bAuthorization\\s*:\\s*(?!Bearer \\*{3,})\\S+/i"]
          }
        ]
      }
    }
  ]
}
