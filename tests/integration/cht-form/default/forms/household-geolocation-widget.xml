<?xml version="1.0"?>
<h:html xmlns:h="http://www.w3.org/1999/xhtml" xmlns="http://www.w3.org/2002/xforms">
  <h:head>
    <h:title>Household Geolocation Test</h:title>
    <model>
      <instance>
        <data id="household_geolocation_test">
          <geo_capture/>
          <meta><instanceID/></meta>
        </data>
      </instance>
      <bind nodeset="/data/geo_capture" type="string" required="true()"/>
    </model>
  </h:head>
  <h:body>
    <input ref="/data/geo_capture" appearance="geolocation-capture">
      <label>Capture GPS Location</label>
    </input>
  </h:body>
</h:html>
