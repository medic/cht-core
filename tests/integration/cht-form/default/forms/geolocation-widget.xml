<?xml version="1.0"?>
<h:html xmlns:h="http://www.w3.org/1999/xhtml" xmlns="http://www.w3.org/2002/xforms">
  <h:head>
    <h:title>Geolocation Test</h:title>
    <model>
      <instance>
        <data id="geolocation_test">
          <geo_capture/>
          <geo_context/>
          <meta><instanceID/></meta>
        </data>
      </instance>
    </model>
  </h:head>
  <h:body>
    <input ref="/data/geo_capture" appearance="geolocation-capture">
      <label>Capture GPS Location</label>
    </input>
    <select1 ref="/data/geo_context" appearance="geolocation-context">
      <label>Where are you capturing GPS location?</label>
      <item><label>At the beneficiary's home</label><value>home</value></item>
      <item><label>At the beneficiary's workplace</label><value>workplace</value></item>
      <item><label>Other</label><value>other</value></item>
    </select1>
  </h:body>
</h:html>
