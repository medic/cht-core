<?xml version="1.0"?>
<h:html xmlns="http://www.w3.org/2002/xforms" xmlns:h="http://www.w3.org/1999/xhtml" xmlns:ev="http://www.w3.org/2001/xml-events" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:jr="http://openrosa.org/javarosa" xmlns:orx="http://openrosa.org/xforms" xmlns:odk="http://www.opendatakit.org/xforms">
  <h:head>
    <h:title>New Person With Geolocation</h:title>
    <model odk:xforms-version="1.0.0">
      <itext>
        <translation lang="en">
          <text id="/data/person_with_geo/name:label">
            <value>Full name</value>
          </text>
          <text id="/data/person_with_geo/geo_capture:label">
            <value>Capture GPS Location</value>
          </text>
        </translation>
      </itext>
      <instance>
        <data id="contact:person_with_geo:create" version="2026-06-09" prefix="J1!contact:person_with_geo:create!" delimiter="#">
          <person_with_geo>
            <parent>PARENT</parent>
            <type>person</type>
            <name/>
            <geo_capture/>
          </person_with_geo>
          <meta tag="hidden">
            <instanceID/>
          </meta>
        </data>
      </instance>
      <bind nodeset="/data/person_with_geo/parent" type="string"/>
      <bind nodeset="/data/person_with_geo/type" type="string"/>
      <bind nodeset="/data/person_with_geo/name" type="string" required="true()"/>
      <bind nodeset="/data/person_with_geo/geo_capture" type="string" required="true()"/>
      <bind nodeset="/data/meta/instanceID" type="string" readonly="true()" jr:preload="uid"/>
    </model>
  </h:head>
  <h:body>
    <group ref="/data/person_with_geo">
      <input ref="/data/person_with_geo/name">
        <label ref="jr:itext('/data/person_with_geo/name:label')"/>
      </input>
      <input ref="/data/person_with_geo/geo_capture" appearance="geolocation-capture">
        <label ref="jr:itext('/data/person_with_geo/geo_capture:label')"/>
      </input>
    </group>
  </h:body>
</h:html>
