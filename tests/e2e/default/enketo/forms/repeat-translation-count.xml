<?xml version="1.0"?>
<h:html xmlns="http://www.w3.org/2002/xforms" xmlns:h="http://www.w3.org/1999/xhtml" xmlns:ev="http://www.w3.org/2001/xml-events" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:jr="http://openrosa.org/javarosa" xmlns:orx="http://openrosa.org/xforms" xmlns:odk="http://www.opendatakit.org/xforms" xmlns:cht="https://communityhealthtoolkit.org">
  <h:head>
    <h:title>Repeat</h:title>
    <model odk:xforms-version="1.0.0">
      <itext>
        <translation lang="en">
          <text id="states-0">
            <value>Victoria</value>
          </text>
          <text id="cities-0">
            <value>Melbourne</value>
          </text>
          <text id="/data/basic:label">
            <value>Cascading Selects:</value>
          </text>
          <text id="/data/basic/state_1:label">
            <value>Select a state:</value>
          </text>
          <text id="/data/basic/count:label">
            <value>How many?</value>
          </text>
          <text id="/data/basic/rep/city_1:label">
            <value>Select a city:</value>
          </text>
        </translation>
        <translation lang="ne">
          <text id="states-0">
            <value>VIC (NE)</value>
          </text>
          <text id="cities-0">
            <value>ML (NE)</value>
          </text>
          <text id="/data/basic:label">
            <value>Cascading Selects: - NE</value>
          </text>
          <text id="/data/basic/state_1:label">
            <value>Select a state: - NE</value>
          </text>
          <text id="/data/basic/count:label">
            <value>How many? NE</value>
          </text>
          <text id="/data/basic/rep/city_1:label">
            <value>Select a city: - NE</value>
          </text>
        </translation>
      </itext>
      <instance>
        <data id="repeat-translation-count" version="20260327115755" prefix="J1!repeat-translation-count!" delimiter="#">
          <basic>
            <state_1/>
            <count>1</count>
            <rep jr:template="">
              <city_1/>
            </rep>
            <rep_count/>
          </basic>
          <meta tag="hidden">
            <instanceID/>
          </meta>
        </data>
      </instance>
      <instance id="contact-summary"/>
      <instance id="user-contact-summary"/>
      <instance id="states">
        <root>
          <item>
            <itextId>states-0</itextId>
            <name>VIC</name>
          </item>
        </root>
      </instance>
      <instance id="cities">
        <root>
          <item>
            <itextId>cities-0</itextId>
            <name>melbourne</name>
          </item>
        </root>
      </instance>
      <bind nodeset="/data/basic/state_1" type="string"/>
      <bind nodeset="/data/basic/count" type="int"/>
      <bind nodeset="/data/basic/rep/city_1" type="string"/>
      <bind nodeset="/data/meta/instanceID" type="string" readonly="true()" jr:preload="uid"/>
      <bind nodeset="/data/basic/rep_count" type="string" readonly="true()" calculate=" /data/basic/count "/>
    </model>
  </h:head>
  <h:body class="pages">
    <group appearance="field-list" ref="/data/basic">
      <label ref="jr:itext('/data/basic:label')"/>
      <select1 ref="/data/basic/state_1">
        <label ref="jr:itext('/data/basic/state_1:label')"/>
        <itemset nodeset="instance('states')/root/item">
          <value ref="name"/>
          <label ref="jr:itext(itextId)"/>
        </itemset>
      </select1>
      <input ref="/data/basic/count">
        <label ref="jr:itext('/data/basic/count:label')"/>
      </input>
      <group ref="/data/basic/rep">
        <label/>
        <repeat nodeset="/data/basic/rep" jr:count="/data/basic/rep_count">
          <select1 ref="/data/basic/rep/city_1">
            <label ref="jr:itext('/data/basic/rep/city_1:label')"/>
            <itemset nodeset="instance('cities')/root/item">
              <value ref="name"/>
              <label ref="jr:itext(itextId)"/>
            </itemset>
          </select1>
        </repeat>
      </group>
    </group>
  </h:body>
</h:html>