<?xml version="1.0"?>
<h:html xmlns="http://www.w3.org/2002/xforms" xmlns:h="http://www.w3.org/1999/xhtml" xmlns:ev="http://www.w3.org/2001/xml-events" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:jr="http://openrosa.org/javarosa" xmlns:orx="http://openrosa.org/xforms" xmlns:odk="http://www.opendatakit.org/xforms" xmlns:cht="https://communityhealthtoolkit.org">
  <h:head>
    <h:title>Cascading select example</h:title>
    <model odk:xforms-version="1.0.0">
      <itext>
        <translation lang="en">
          <text id="states-0">
            <value>Texas</value>
          </text>
          <text id="states-1">
            <value>Washington</value>
          </text>
          <text id="counties-0">
            <value>King</value>
          </text>
          <text id="counties-1">
            <value>Pierce</value>
          </text>
          <text id="counties-2">
            <value>Brewster</value>
          </text>
          <text id="counties-3">
            <value>Cameron</value>
          </text>
          <text id="cities-0">
            <value>Brownsville</value>
          </text>
          <text id="cities-1">
            <value>Harlingen</value>
          </text>
          <text id="cities-2">
            <value>Seattle</value>
          </text>
          <text id="cities-3">
            <value>Redmond</value>
          </text>
          <text id="cities-4">
            <value>Tacoma</value>
          </text>
          <text id="cities-5">
            <value>Puyallup</value>
          </text>
          <text id="/data/page/selected_state:label">
            <value>Select a state</value>
          </text>
          <text id="/data/page/selected_county:label">
            <value>Select a county</value>
          </text>
          <text id="/data/page/selected_city:label">
            <value>Select a city</value>
          </text>
        </translation>
      </itext>
      <instance>
        <data id="repeat-translation-select" version="20260327115653" prefix="J1!repeat-translation-select!" delimiter="#">
          <page>
            <selected_state/>
            <selected_county/>
            <selected_city/>
          </page>
          <meta tag="hidden">
            <instanceID/>
          </meta>
        </data>
      </instance>
      <instance id="contact-summary"/>
      <instance id="user-contact-summary"/>
      <instance id="states">
        <root>
          <item>
            <itextId>states-0</itextId>
            <name>texas</name>
          </item>
          <item>
            <itextId>states-1</itextId>
            <name>washington</name>
          </item>
        </root>
      </instance>
      <instance id="counties">
        <root>
          <item>
            <itextId>counties-0</itextId>
            <name>king</name>
            <state>washington</state>
          </item>
          <item>
            <itextId>counties-1</itextId>
            <name>pierce</name>
            <state>washington</state>
          </item>
          <item>
            <itextId>counties-2</itextId>
            <name>brewster</name>
            <state>texas</state>
          </item>
          <item>
            <itextId>counties-3</itextId>
            <name>cameron</name>
            <state>texas</state>
          </item>
        </root>
      </instance>
      <instance id="cities">
        <root>
          <item>
            <itextId>cities-0</itextId>
            <name>brownsville</name>
            <state>texas</state>
            <county>cameron</county>
          </item>
          <item>
            <itextId>cities-1</itextId>
            <name>harlingen</name>
            <state>texas</state>
            <county>cameron</county>
          </item>
          <item>
            <itextId>cities-2</itextId>
            <name>seattle</name>
            <state>washington</state>
            <county>king</county>
          </item>
          <item>
            <itextId>cities-3</itextId>
            <name>redmon</name>
            <state>washington</state>
            <county>king</county>
          </item>
          <item>
            <itextId>cities-4</itextId>
            <name>tacoma</name>
            <state>washington</state>
            <county>pierce</county>
          </item>
          <item>
            <itextId>cities-5</itextId>
            <name>puyallup</name>
            <state>washington</state>
            <county>pierce</county>
          </item>
        </root>
      </instance>
      <bind nodeset="/data/page/selected_state" type="string"/>
      <bind nodeset="/data/page/selected_county" type="string"/>
      <bind nodeset="/data/page/selected_city" type="string"/>
      <bind nodeset="/data/meta/instanceID" type="string" readonly="true()" jr:preload="uid"/>
    </model>
  </h:head>
  <h:body class="pages">
    <group appearance="field-list" ref="/data/page">
      <select1 ref="/data/page/selected_state">
        <label ref="jr:itext('/data/page/selected_state:label')"/>
        <itemset nodeset="instance('states')/root/item">
          <value ref="name"/>
          <label ref="jr:itext(itextId)"/>
        </itemset>
      </select1>
      <select1 ref="/data/page/selected_county">
        <label ref="jr:itext('/data/page/selected_county:label')"/>
        <itemset nodeset="instance('counties')/root/item[state= /data/page/selected_state ]">
          <value ref="name"/>
          <label ref="jr:itext(itextId)"/>
        </itemset>
      </select1>
      <select1 ref="/data/page/selected_city">
        <label ref="jr:itext('/data/page/selected_city:label')"/>
        <itemset nodeset="instance('cities')/root/item[county= /data/page/selected_county ]">
          <value ref="name"/>
          <label ref="jr:itext(itextId)"/>
        </itemset>
      </select1>
    </group>
  </h:body>
</h:html>