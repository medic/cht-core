/* To learn more about this file see: https://angular.io/config/tsconfig. */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": [
      "mocha",
      "sinon",
      "node",
      "jquery",
      "sinon-chai"
    ]
  },
  "files": [
    "tests/karma/test.ts",
    "src/ts/polyfills.ts"
  ],
  "include": [
    "tests/karma/**/*.spec.ts",
    "tests/karma/**/*.d.ts"
  ],
  // Override the temporary "tests/**" exclusion in tsconfig.json so karma still compiles the specs.
  "exclude": []
}
